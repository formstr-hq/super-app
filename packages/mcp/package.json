{
  "name": "@formstr/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Formstr super-app — drive Nostr forms (and more) from any MCP host, with secure keychain/NIP-46 login.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nostr",
    "formstr",
    "forms",
    "ai-tools"
  ],
  "homepage": "https://github.com/formstr-hq/super-app/tree/main/packages/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formstr-hq/super-app.git",
    "directory": "packages/mcp"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "formstr-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.6"
  },
  "devDependencies": {
    "@formstr/agent": "workspace:*",
    "@formstr/core": "workspace:*",
    "@formstr/signer": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.0",
    "nostr-tools": "^2.23.3",
    "qrcode": "^1.5.4",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  }
}
