{
  "name": "@formstr/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./signer": {
      "types": "./dist/signer/index.d.ts",
      "import": "./dist/signer/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js"
    },
    "./blossom": {
      "types": "./dist/blossom/index.d.ts",
      "import": "./dist/blossom/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./linking": {
      "types": "./dist/linking.d.ts",
      "import": "./dist/linking.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "nostr-tools": "^2.16.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.1.0"
  }
}
